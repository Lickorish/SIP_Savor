<%- include('partials/header', {title: establishment.name}) %>

<!-- Hero -->
<div class="place-hero">
  <div class="place-hero-inner">
    <div class="eyebrow"><%= establishment.type %></div>
    <h1><%= establishment.name %></h1>
    <% if (establishment.city || establishment.address) { %>
      <p class="address"><%= [establishment.address, establishment.city, establishment.country].filter(Boolean).join(', ') %></p>
    <% } %>
    <% if (establishment.website) { %>
      <a href="<%= establishment.website %>" target="_blank" rel="noopener"
        style="display:inline-flex; align-items:center; gap:0.4rem; margin-top:0.5rem; color:var(--caramel); font-size:0.9rem; text-decoration:none;">
        🌐 <%= establishment.website.replace(/^https?:\/\//, '') %>
      </a>
    <% } %>
    <div class="rating-summary">
      <% if (establishment.avg_rating) { %>
        <span class="big-rating"><%= establishment.avg_rating %></span>
        <div>
          <div class="stars" style="font-size:1.4rem">
            <% const avg = Math.round(parseFloat(establishment.avg_rating)); %>
            <% for (let i=1; i<=5; i++) { %>
              <span class="star <%= i<=avg ? 'filled' : '' %>" style="color: <%= i<=avg ? 'var(--gold)' : 'rgba(255,255,255,0.2)' %>">★</span>
            <% } %>
          </div>
          <p style="color:var(--parchment); opacity:0.75; font-size:0.85rem; margin-top:0.2rem">
            <%= establishment.review_count %> review<%= establishment.review_count!==1?'s':'' %>
            <% if (establishment.added_by_name) { %>&mdash; first added by <%= establishment.added_by_name %><% } %>
          </p>
        </div>
      <% } else { %>
        <p style="color:var(--parchment); opacity:0.75; font-style:italic">No reviews yet &mdash; be the first!</p>
      <% } %>
    </div>
  </div>

  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <form method="POST" action="/place/<%= establishment.id %>/delete" style="margin-top:1.25rem">
      <button type="submit" class="btn btn-danger btn-sm"
        onclick="return confirm('Permanently delete <%= establishment.name %> and all its reviews and photos? This cannot be undone.')">
        🗑 Delete this place
      </button>
    </form>
  <% } %>

</div>
</div>

<div class="place-layout">

  <!-- Reviews -->
  <div class="reviews-col">
    <h2 style="margin-bottom:1.25rem">
      Reviews
      <span style="font-size:1rem; font-weight:400; color:var(--muted); font-family:Lora,serif">
        (<%= reviews.length %>)
      </span>
    </h2>

    <% if (reviews.length === 0) { %>
      <div class="empty-state" style="padding:2.5rem">
        <div class="icon">✍️</div>
        <h3>No reviews yet</h3>
        <p>Add yours using the form →</p>
      </div>
    <% } else { %>
      <div class="reviews-list">
        <% reviews.forEach(r => { %>
          <div class="review-card <%= r.user_id === parseInt(establishment.added_by) && r.id === reviews[reviews.length-1]?.id ? '' : '' %> <%= r.user_id === parseInt(establishment.added_by) ? 'own' : '' %>">
            <div class="review-header">
              <div>
                <div class="reviewer-name"><%= r.display_name %></div>
                <div class="star-display" style="margin-top:0.2rem">
                  <div class="stars">
                    <% for (let i=1; i<=5; i++) { %>
                      <span class="star <%= i<=r.rating?'filled':'' %>">★</span>
                    <% } %>
                  </div>
                  <span style="font-family:'DM Mono',monospace; font-size:0.75rem; color:var(--muted)"><%= r.rating %>/5</span>
                </div>
              </div>
              <div style="text-align:right">
                <div class="review-date">
                  <% if (r.visited_date) { %>
                    Visited <%= new Date(r.visited_date).toLocaleDateString('en-GB', {day:'numeric', month:'short', year:'numeric'}) %>
                    <br>
                  <% } %>
                  Reviewed <%= new Date(r.created_at).toLocaleDateString('en-GB', {day:'numeric', month:'short', year:'numeric'}) %>
                </div>
                <% if (r.user_id === parseInt(establishment.added_by) && reviews.indexOf(r) === 0) { %>
                  <!-- first reviewer badge could go here -->
                <% } %>
              </div>
            </div>

            <% if (r.comment) { %>
              <p class="review-comment">"<%= r.comment %>"</p>
            <% } %>

            <% const photos = Array.isArray(r.photos) ? r.photos : JSON.parse(r.photos || '[]'); %>
            <% if (photos.length > 0) { %>
              <div class="review-photos">
                <% photos.forEach(url => { %>
                  <img src="<%= url %>" alt="Photo from <%= r.username %>">
                <% }) %>
              </div>
            <% } %>

            <!-- Delete if own review or admin -->
            <% if (r.user_id === parseInt(establishment.added_by) || (typeof isAdmin !== 'undefined' && isAdmin)) { %>
              <% /* We need user session ID — check via inline comparison. The view has access to userReview */ %>
            <% } %>
            <!-- We compare by username since we don't pass userId directly to template -->
            <% if (r.username === user || (typeof isAdmin !== 'undefined' && isAdmin)) { %>
              <form method="POST" action="/review/<%= r.id %>/delete" style="margin-top:0.75rem">
                <button type="submit" class="btn btn-ghost btn-sm" onclick="return confirm('Delete this review?')"
                  style="color:#c0392b; border-color:#e8a0a0; font-size:0.75rem">
                  Delete review
                </button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Add review form -->
  <div class="form-col">
    <div class="card" style="position:sticky; top:80px">
      <h3 style="margin-bottom:1.25rem">Add Your Review</h3>

      <form method="POST" action="/place/<%= establishment.id %>/review" enctype="multipart/form-data">

        <div class="form-group">
          <label>Rating <span style="color:#c0392b">*</span></label>
          <div class="star-input">
            <input type="radio" id="r5" name="rating" value="5"><label for="r5">★</label>
            <input type="radio" id="r4" name="rating" value="4"><label for="r4">★</label>
            <input type="radio" id="r3" name="rating" value="3"><label for="r3">★</label>
            <input type="radio" id="r2" name="rating" value="2"><label for="r2">★</label>
            <input type="radio" id="r1" name="rating" value="1"><label for="r1">★</label>
          </div>
        </div>

        <div class="form-group">
          <label for="comment">Comments <span class="hint">(optional)</span></label>
          <textarea id="comment" name="comment" rows="4" placeholder="Your thoughts…"></textarea>
        </div>

        <div class="form-group">
          <label for="visited_date">Date visited <span class="hint">(optional)</span></label>
          <input type="date" id="visited_date" name="visited_date">
        </div>

        <div class="form-group">
          <label>Photos <span class="hint">(up to 5)</span></label>
          <div class="photo-upload-area" onclick="document.getElementById('photos').click()" style="padding:1rem">
            <input type="file" id="photos" name="photos" accept="image/*" multiple>
            <p style="color:var(--muted); font-size:0.8rem; font-style:italic">Click to add photos</p>
          </div>
          <div class="photo-preview" id="photo-preview"></div>
        </div>

        <button type="submit" class="btn btn-primary btn-full">Post Review</button>
      </form>
    </div>
  </div>

</div>


<%- include('partials/footer') %>
