<%- include('partials/header', {title: 'Admin'}) %>

<div class="page-header">
  <div class="eyebrow">Administration</div>
  <h1>Manage Members</h1>
  <p>Invite people and manage access</p>
</div>

<div class="container">

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <div class="admin-layout">

    <!-- User list -->
    <div class="admin-users-col">
    <div class="card">
      <h3 style="margin-bottom:1.25rem">Members (<%= users.length %>)</h3>
      <div class="table-wrap"><table class="data-table">
        <thead>
          <tr>
            <th>Username</th>
            <th>Display name</th>
            <th>Role</th>
            <th>Member since</th>
            <th>Last login</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td style="font-family:'Playfair Display',serif; font-weight:600"><%= u.username %></td>
              <td><%= u.display_name || '—' %></td>
              <td>
                <span class="badge <%= u.is_admin ? 'badge-admin' : 'badge-member' %>">
                  <%= u.is_admin ? 'Admin' : 'Member' %>
                </span>
              </td>
              <td style="font-family:'DM Mono',monospace; font-size:0.8rem; color:var(--muted)">
                <%= new Date(u.created_at).toLocaleDateString('en-GB', {day:'numeric', month:'short', year:'numeric'}) %>
              </td>
              <td style="font-family:'DM Mono',monospace; font-size:0.8rem; color:var(--muted)">
                <% if (u.last_login) { %>
                  <%= new Date(u.last_login).toLocaleDateString('en-GB', {day:'numeric', month:'short', year:'numeric'}) %>
                  <span style="opacity:0.6"><%= new Date(u.last_login).toLocaleTimeString('en-GB', {hour:'2-digit', minute:'2-digit'}) %></span>
                <% } else { %>
                  <span style="opacity:0.4; font-style:italic">Never</span>
                <% } %>
              </td>
              <td>
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap">
                  <!-- Reset password inline form -->
                  <button
                    class="btn btn-ghost btn-sm"
                    onclick="document.getElementById('reset-<%= u.id %>').style.display='block'; this.style.display='none'"
                  >Reset pw</button>

                  <% if (u.username !== user) { %>
                    <form method="POST" action="/admin/users/<%= u.id %>/delete">
                      <button type="submit" class="btn btn-danger btn-sm"
                        onclick="return confirm('Remove <%= u.username %>?')">Remove</button>
                    </form>
                  <% } %>
                </div>
                <form id="reset-<%= u.id %>" method="POST" action="/admin/users/<%= u.id %>/reset-password"
                  style="display:none; margin-top:0.5rem">
                  <div style="display:flex; gap:0.4rem">
                    <input type="password" name="new_password" placeholder="New password" minlength="6"
                      style="font-size:0.8rem; padding:0.35rem 0.6rem">
                    <button type="submit" class="btn btn-primary btn-sm">Set</button>
                  </div>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table></div>
    </div>

    </div><!-- /admin-users-col -->
    <!-- Invite / create user -->
    <div class="admin-form-col">
    <div class="card">
      <h3 style="margin-bottom:1.25rem">Invite a Member</h3>
      <form method="POST" action="/admin/users/create">

        <div class="form-group">
          <label for="username">Username <span class="hint">(for login)</span></label>
          <input type="text" id="username" name="username"
            placeholder="e.g. carol" autocomplete="off" required>
        </div>
        <div class="form-group">
          <label for="display_name">Display name <span class="hint">(shown on reviews)</span></label>
          <input type="text" id="display_name" name="display_name"
            placeholder="e.g. Carol">
        </div>

        <div class="form-group">
          <label for="password">Temporary password</label>
          <input type="password" id="password" name="password"
            placeholder="Min 6 characters" minlength="6" required>
        </div>

        <div class="form-group" style="display:flex; align-items:center; gap:0.5rem">
          <input type="checkbox" id="is_admin" name="is_admin" style="width:auto">
          <label for="is_admin" style="margin:0; font-size:0.9rem; cursor:pointer">
            Give admin access
          </label>
        </div>

        <button type="submit" class="btn btn-primary btn-full">Create Member</button>
      </form>

      <hr class="divider" style="margin:1.5rem 0">

      <p style="font-size:0.8rem; color:var(--muted); font-style:italic; line-height:1.6">
        Share the app URL and their username &amp; temporary password directly.
        Ask them to note it down — passwords are stored as hashes and cannot be recovered.
      </p>
    </div>
    </div><!-- /admin-form-col -->

  </div>
</div>

<%- include('partials/footer') %>
